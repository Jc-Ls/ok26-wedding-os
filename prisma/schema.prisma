generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Guest {
  id            String   @id @default(cuid())
  fullName      String
  phone         String
  reservationId String   @unique
  hasEntered    Boolean  @default(false)
  createdAt     DateTime @default(now())
}
model Order {
  id          String   @id @default(cuid())
  tableNumber String
  guestName   String?
  guestPhone  String?
  mealName    String?
  drinkName   String?
  withSalad   Boolean  @default(false)
  status      String   @default("SENT")
  createdAt   DateTime @default(now())
}
model ConciergeRequest {
  id          String   @id @default(cuid())
  tableNumber String
  guestName   String
  requestType String   // e.g., "WATER", "CUTLERY", "CLEAR_TABLE"
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}
model Reservation {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  name      String
  email     String?  // The ? makes it optional in the database
  phone     String?
  createdAt DateTime @default(now())
}
