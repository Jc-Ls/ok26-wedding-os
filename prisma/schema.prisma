generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guest {
  id            String   @id @default(cuid())
  fullName      String
  phone         String
  email         String?
  reservationId String   @unique
  tableNumber   String?
  ticketId      String?
  guestCategory String?
  hasEntered    Boolean  @default(false)
  createdAt     DateTime @default(now())
}
model Order {
  id            String   @id @default(cuid())
  tableNumber   String
  guestName     String?
  guestPhone    String?
  ticketId      String?
  mealName      String?
  drinkName     String?
  withSalad     Boolean  @default(false)
  souvenirNudge Boolean  @default(false)
  nudgeCount    Int      @default(0)
  status        String   @default("Pending")
  deliveredBy   String?
  createdAt     DateTime @default(now())
}
model ConciergeRequest {
  id          String   @id @default(cuid())
  tableNumber String
  guestName   String
  requestType String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}
model Reservation {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
}
model VipPass {
  id        String   @id @default(cuid())
  code      String   @unique
  isUsed    Boolean  @default(false)
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime @default(now())
}
model MenuItem {
  id          String   @id @default(cuid())
  name        String
  category    String   
  imageUrl    String?  
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}
